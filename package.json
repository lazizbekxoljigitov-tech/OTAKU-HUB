{
  "name": "Login",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./elektron/main.js",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"npm run wait-electron\"",
    "wait-electron": "wait-on http://localhost:5173 && electron .",
    "watch-electron": "nodemon --watch elektron --exec electron ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "axios": "^1.18.1",
    "concurrently": "^10.0.3",
    "gsap": "^3.15.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "styled-components": "^6.4.2",
    "swiper": "^12.2.0",
    "tailwindcss": "^4.3.1",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "vite": "^8.0.12"
  }
}
